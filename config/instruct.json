{
    "model": {
        "d_model": 720,
        "nhead": 8,
        "dim_feedforward": 2880,
        "dropout": 0.05,
        "transformer_layers": 10,
        "max_len": 512
    },
    "training": {
        "max_hours": 4.5,
        "grad_accum": 2,
        "max_steps": 100000,
        "warmup_steps": 100,
        "log_every": 20,
        "eval_every": 200,
        "lr": 5e-5,
        "lr_min": 5e-6,
        "batch_size": 8
    },
    "manual_data_path": "../data/manual_data.json",
    "dataset": {
        "alpaca_name": "tatsu-lab/alpaca",
        "alpaca_split": "train",
        "alpaca_max": 2000,
        "alpaca_max_output_len": 150,
        "alpaca_max_instruction_len": 80,
        "alpaca_min_output_len": 15,
        "manual_repeat": 10,
        "train_split": 0.95
    },
    "pretrained_weights": "../weights/best.pt",
    "save_dir": "../weights/instruct"
}
